<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="horizontal"
    android:padding="12dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?android:attr/selectableItemBackground">

    <!-- Bagian kiri: informasi teks -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="152dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvNamaEskul"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nama Eskul"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvNamaPembina"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Pembina: ..."
            android:textSize="16sp" />

        <TextView
            android:id="@+id/tvJamMulai"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Jam Mulai: ..."
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvJamSelesai"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Jam Selesai: ..."
            android:textSize="14sp" />

        <Button
            android:id="@+id/btnEdit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Edit Eskul" />
    </LinearLayout>

    <!-- Bagian kanan: gambar eskul -->
    <ImageView
        android:id="@+id/imgEskul"
        android:layout_width="150dp"
        android:layout_height="150dp"
        android:src="@drawable/ic_default_eskul"
        android:scaleType="centerCrop"
        android:layout_gravity="center_vertical"
        android:layout_marginStart="8dp" />

</LinearLayout>
